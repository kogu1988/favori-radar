{
  "manifest_version": 3,
  "name": "Favori Radar",
  "description": "Favori ilanlarınızın fiyat geçmişini cihazınızda takip eder.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["alarms", "storage", "tabs"],
  "host_permissions": [
    "https://www.sahibinden.com/*",
    "https://banaozel.sahibinden.com/*"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.sahibinden.com/*",
        "https://banaozel.sahibinden.com/*"
      ],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Favori Radar",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
